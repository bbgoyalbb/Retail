# ============================================================
# Backend environment variables — copy to .env and fill in
# ============================================================

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017

# MongoDB database name
DB_NAME=retail_db

# Comma-separated allowed CORS origins (use * for dev; restrict in prod)
CORS_ORIGINS=http://localhost:3000

# JWT secret key — change to a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret

# API key for backup/restore endpoints (leave blank to disable auth)
ADMIN_API_KEY=

# Path to Excel seed file (used by /seed endpoint)
SEED_FILE_PATH=/tmp/retail_book.xlsm
