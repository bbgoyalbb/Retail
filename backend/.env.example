# Required: MongoDB connection URL
MONGO_URL=mongodb://localhost:27017

# Required: MongoDB database name
DB_NAME=retail_db

# Optional: Comma-separated list of allowed CORS origins.
# Use * to allow all origins (dev only). Restrict in production.
# Example: CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Optional: Admin API key for backup and restore endpoints.
# Leave unset to disable auth (development mode only).
# Set a strong random value in production.
ADMIN_API_KEY=

# Optional: Absolute path to the Excel seed file.
# Only used when the database is empty and REACT_APP_ENABLE_SEED=true on the frontend.
SEED_FILE_PATH=/tmp/retail_book.xlsm